@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <style>

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background-color: #1a2a4a;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
                margin: 0;
            }

            .form {
                background: white;
                padding: 40px;
                border-radius: 10px;
                width: 320px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.3);
            }

            input {
                width: 100%;
                padding: 10px;
                margin: 8px 0;
                border: 1px solid #ccc;
                border-radius: 5px;
                box-sizing: border-box;
            }

            button {
                width: 100%;
                padding: 10px;
                margin-top: 10px;
                background-color: #1a2a4a;
                color: white;
                border: none;
                border-radius: 5px;
                cursor: pointer;
            }

                button:hover {
                    background-color: #2a3f6f;
                }

            .message {
                text-align: center;
                margin-top: 12px;
                font-size: 0.90rem;
            }

                .message a {
                    color: red;
                    text-decoration: none;
                    font-weight: bold;
                }

                    .message a:hover {
                        text-decoration: underline;
                    }

            .error {
                color: red;
                font-size: 0.90rem;
                text-align: center;
                margin-bottom: 8px;
            }
    </style>
</head>
<body>
    <div class="form">
            <div style ="text-align:center; margin-bottom:20px;">
                <img src="/images/WWS.png" width="250" height="100">
            </div>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        <!-- Login Form -->
        <form class="login-form" method="post" action="/Account/Login">
            @Html.AntiForgeryToken()
            <input type="Text" name="username" placeholder="Username" />
            <input type="password" name="password" placeholder="Password" />
            <button type="Submit">Login</button>
            <p class="message">Not registered? <a href="/Account/Register">Create an account</a></p>
            <p class="message"><a href="/Account/ForgotPassword">Forgot Password?</a></p>
        </form>

    </div>
</body>
</html>