@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Verify Account</title>
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background-color: #1a2a4a;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
            }

            .form {
                background: white;
                padding: 40px;
                border-radius: 10px;
                width: 360px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.3);
                text-align: center;
            }

                .form h2 {
                    color: #1a2a4a;
                    margin-bottom: 8px;
                    font-size: 1.2rem;
                }

                .form p.subtitle {
                    color: #555;
                    font-size: 0.85rem;
                    margin-bottom: 24px;
                }

            .code-inputs {
                display: flex;
                justify-content: center;
                gap: 10px;
                margin-bottom: 20px;
            }

                .code-inputs input {
                    width: 44px;
                    height: 54px;
                    text-align: center;
                    font-size: 1.4rem;
                    font-weight: bold;
                    border: 2px solid #ccc;
                    border-radius: 8px;
                    outline: none;
                    color: #1a2a4a;
                    transition: border-color 0.2s;
                }

                    .code-inputs input:focus {
                        border-color: #1a2a4a;
                    }

            button {
                width: 100%;
                padding: 10px;
                background-color: #1a2a4a;
                color: white;
                border: none;
                border-radius: 5px;
                cursor: pointer;
                font-size: 1rem;
            }

                button:hover {
                    background-color: #2a3f6f;
                }

            .error {
                color: red;
                font-size: 0.85rem;
                text-align: center;
                margin-bottom: 12px;
            }
    </style>
</head>
<body>
    <div class="form">
        <div style="text-align:center; margin-bottom:20px;">
            <img src="/images/WWS.png" width="250" height="90">
        </div>

        <h2>Check your email</h2>
        <p class="subtitle">We sent a 6-digit code to your email address.<br>It expires in 15 minutes.</p>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        <form method="post" action="/Account/Verify">
            @Html.AntiForgeryToken()

            <!-- Hidden input that gets assembled from the 6 boxes -->
            <input type="hidden" name="code" id="hiddenCode" />

            <div class="code-inputs">
                <input type="text" inputmode="numeric" maxlength="1" class="digit" id="d1" />
                <input type="text" inputmode="numeric" maxlength="1" class="digit" id="d2" />
                <input type="text" inputmode="numeric" maxlength="1" class="digit" id="d3" />
                <input type="text" inputmode="numeric" maxlength="1" class="digit" id="d4" />
                <input type="text" inputmode="numeric" maxlength="1" class="digit" id="d5" />
                <input type="text" inputmode="numeric" maxlength="1" class="digit" id="d6" />
            </div>

            <button type="submit">Verify</button>
        </form>
    </div>

    <script>
            const digits = Array.from(document.querySelectorAll('.digit'));

            digits.forEach((input, index) => {
                // Only allow numbers
                input.addEventListener('keypress', (e) => {
                    if (!/[0-9]/.test(e.key)) e.preventDefault();
                });

                // Auto-advance on input
                input.addEventListener('input', () => {
                    input.value = input.value.replace(/[^0-9]/g, '');
                    if (input.value && index < digits.length - 1) {
                        digits[index + 1].focus();
                    }
                });

                // Backspace goes back to previous box
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !input.value && index > 0) {
                        digits[index - 1].focus();
                    }
                });
            });

            // Before submitting, assemble all 6 digits into the hidden input
            document.querySelector('form').addEventListener('submit', () => {
                document.getElementById('hiddenCode').value = digits.map(d => d.value).join('');
            });
    </script>
</body>
</html>
