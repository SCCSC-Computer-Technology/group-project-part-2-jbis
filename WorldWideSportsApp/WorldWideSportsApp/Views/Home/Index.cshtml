@{
    ViewData["Title"] = "Home Page";
    var games = ViewBag.Games as List<WorldWideSportsLibrary.NFLGames>;
    var tournaments = ViewBag.Tournaments as List<WorldWideSportsLibrary.PGATournament>;
}

<style>
    body { background-color: lightblue; }

    .sports-section {
        clear: both;
        margin-top: 2rem;
        padding: 1rem 0;
    }

    .section-title {
        font-family: 'Cooper', serif;
        font-size: 1.8rem;
        text-align: center;
        margin-bottom: 1.2rem;
        padding-bottom: 0.4rem;
        border-bottom: 3px solid brown;
        color: #003366;
    }

    .pga-title { border-color: green; color: #1a4731; }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 1rem;
        padding: 0 1rem;
    }

    .card-item {
        background: lightgreen;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.12);
    }

    .card-item .teams {
        font-family: Cooper;
        font-size: 1rem;
        font-weight: 700;
        color: #003366;
        margin-bottom: 0.25rem;
    }

    .card-item .detail {
        font-family: Cooper;
        font-size: 0.85rem;
        color: #555;
    }

    .badge {
        display: inline-block;
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 20px;
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        font-weight: 600;
    }

    .badge-nfl  { background: #003366; color: white; }
    .badge-pga  { background: #1a4731; color: white; }
</style>

<div class="text-center">
    <h1 style="font-family: Cooper" class="display-4">Welcome to World Wide Sports!</h1>
    <p style="font-family: 'Cooper'" class="lead">You can view the stats for your favorite NFL team or PGA golfer here!</p>
</div>

<img src="/images/NFL.png" class="rounded float-start w-25" alt="">
<img src="/images/PGA-of-America-Symbol.png" class="rounded float-end w-25" alt="">

<!-- NFL Games -->
<div class="sports-section">
    <h2 class="section-title">🏈 Upcoming NFL Games — 2025 Season</h2>
    <div class="cards-grid">
        @if (games != null && games.Count > 0)
        {
            @foreach (var g in games)
            {
                <div class="card-item">
                    <span class="badge badge-nfl">Week @g.Week</span>
                    <div class="teams">@g.AwayTeam vs @g.HomeTeam</div>
                    <div class="detail">📅 @g.Gameday.ToString("ddd, MMM d")</div>
                    <div class="detail">🕐 @g.Gametime</div>
                    <div class="detail">🏟️ @g.Stadium</div>
                </div>
            }
        }
        else
        {
            <p class="text-center">No upcoming games found.</p>
        }
    </div>
</div>

<!-- PGA Tournaments -->
<div class="sports-section">
    <h2 class="section-title pga-title">⛳ Upcoming PGA Tournaments</h2>
    <div class="cards-grid">
        @if (tournaments != null && tournaments.Count > 0)
        {
            @foreach (var t in tournaments)
            {
                <div class="card-item">
                    <span class="badge badge-pga">@t.Season</span>
                    <div class="teams">@t.Tournament</div>
                    <div class="detail">📍 @t.Location</div>
                </div>
            }
        }
        else
        {
            <p class="text-center">No tournament data found.</p>
        }
    </div>
</div>