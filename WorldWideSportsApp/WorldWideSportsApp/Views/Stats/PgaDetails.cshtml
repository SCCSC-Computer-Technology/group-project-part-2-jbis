@model List<WorldWideSportsLibrary.PGAPlayerStats>
@{
    ViewData["Title"] = "PGA Player Stats";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { background-color: #1a2a4a; }

    .stats-wrapper { padding: 20px 30px; }

    h2 {
        color: white;
        font-family: 'Cooper', serif;
        margin-bottom: 20px;
    }

    .filter-bar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 20px;
        align-items: flex-end;
    }

    .filter-bar select,
    .filter-bar input {
        padding: 8px 12px;
        border-radius: 6px;
        border: none;
        font-size: 0.9rem;
        min-width: 160px;
    }

    .filter-bar button {
        padding: 8px 22px;
        background: #005f20;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .filter-bar button:hover { background: #004418; }

    .table-wrap { overflow-x: auto; }

    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
        font-size: 0.88rem;
    }

    thead {
        background-color: #1a2a4a;
        color: white;
    }

    thead th {
        padding: 12px 14px;
        text-align: left;
        white-space: nowrap;
    }

    tbody tr:nth-child(even) { background: #f2f4f8; }
    tbody tr:hover { background: #dce3f0; }

    tbody td {
        padding: 10px 14px;
        white-space: nowrap;
    }

    .money {
        color: #2d8a2d;
        font-weight: bold;
    }

    .no-data {
        color: white;
        text-align: center;
        padding: 50px;
        font-size: 1.1rem;
    }
</style>

<div class="stats-wrapper">

    <h2>⛳ PGA Player Stats</h2>

    <form method="get" action="/Stats/PgaDetails">
        <div class="filter-bar">

            <select name="season">
                @foreach (var s in ViewBag.Seasons)
                {
                    if (s == (int)ViewBag.SelSeason)
                    {
                        <option value="@s" selected>@s Season</option>
                    }
                    else
                    {
                        <option value="@s">@s Season</option>
                    }
                }
            </select>

            <input type="text"
                   name="player"
                   value="@ViewBag.SelPlayer"
                   placeholder="Search player name..." />

            <button type="submit">Filter</button>

        </div>
    </form>

    <div class="table-wrap">
        @if (Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>Season</th>
                        <th>Events</th>
                        <th>Wins</th>
                        <th>Top 10s</th>
                        <th>Avg Score</th>
                        <th>Earnings</th>
                        <th>FedEx Points</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><strong>@p.PlayerName</strong></td>
                            <td>@p.Season</td>
                            <td>@p.EventsPlayed</td>
                            <td>@p.Wins</td>
                            <td>@p.TopTenFinish</td>
                            <td>@p.AverageScore.ToString("F2")</td>
                            <td class="money">$@p.TotalEarnings.ToString("N0")</td>
                            <td>@p.TotalFedXPoints.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="no-data">No players found for the selected filters.</p>
        }
    </div>

</div>
